{
  "name": "browser-pilot",
  "version": "1.0.0",
  "description": "An MCP server that launches Chrome in remote debugging mode and exposes full Playwright browsing capabilities",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "browser-pilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts"
  },
  "keywords": [
    "mcp",
    "browser",
    "playwright",
    "chrome",
    "automation",
    "cdp"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright-core": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
